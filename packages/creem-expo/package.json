{
  "name": "creem-expo",
  "version": "0.2.0",
  "description": "Creem payments SDK for Expo/React Native apps",
  "license": "MIT",
  "author": "malakhov",
  "keywords": ["creem", "expo", "react-native", "payments", "subscriptions", "checkout", "MoR", "config-plugin"],
  "repository": {
    "type": "git",
    "url": "https://github.com/malakhov-dmitrii/creem-expo"
  },
  "exports": {
    ".": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.mjs",
      "require": "./dist/client/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.mjs",
      "require": "./dist/server/index.js"
    },
    "./plugin": {
      "types": "./dist/plugin/index.d.ts",
      "require": "./dist/plugin/index.js"
    }
  },
  "main": "./dist/client/index.js",
  "module": "./dist/client/index.mjs",
  "types": "./dist/client/index.d.ts",
  "files": [
    "dist",
    "app.plugin.js",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "jest --config jest.config.ts",
    "test:server": "vitest run --config vitest.config.ts",
    "test:all": "npm run test && npm run test:server",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@expo/config-plugins": ">=7.0.0",
    "expo-linking": ">=6.0.0",
    "expo-web-browser": ">=13.0.0",
    "react": ">=18.0.0",
    "react-native": ">=0.72.0",
    "react-native-webview": ">=13.0.0"
  },
  "peerDependenciesMeta": {
    "@expo/config-plugins": {
      "optional": true
    },
    "react-native-webview": {
      "optional": true
    },
    "expo-web-browser": {
      "optional": true
    }
  },
  "devDependencies": {
    "@expo/config-plugins": "^10.0.0",
    "@expo/config-types": "^52.0.0",
    "@testing-library/react-native": "^12.0.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.0",
    "@types/react": "^18.2.0",
    "@types/supertest": "^6.0.0",
    "@vitest/coverage-v8": "^3.1.4",
    "babel-preset-expo": "^55.0.11",
    "creem": "^1.3.6",
    "expo-linking": "^7.0.0",
    "expo-modules-core": "^55.0.15",
    "expo-web-browser": "^14.0.0",
    "express": "^4.21.0",
    "jest": "^29.7.0",
    "jest-expo": "~52.0.0",
    "react": "^18.2.0",
    "react-native": "^0.76.0",
    "react-native-webview": "^13.0.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.0.0",
    "typescript": "~5.8.0",
    "vitest": "^3.0.0"
  },
  "optionalDependencies": {
    "creem": "^1.3.6"
  }
}
